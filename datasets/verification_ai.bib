@CONFERENCE{Arafah2025,
	author = {Arafah, Yasir and Shejin, Sumaiya and Akhter, Shamim and Khandaker, Md Arafat Alam},
	title = {Multimodal Classification of Software Issue Reports Using CLIP: A Fine-Tuned Approach for Bug and Feature Detection},
	year = {2025},
	journal = {2025 International Conference on Electrical, Computer and Communication Engineering, ECCE 2025},
	doi = {10.1109/ECCE64574.2025.11012920},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105007833116&doi=10.1109%2fECCE64574.2025.11012920&partnerID=40&md5=e540ae9d0b29068fdf81a529cd5f816d},
	affiliations = {Ahsanullah University of Science and Technology, Aisip Lab, Department of Computer Science and Engineering, Dhaka, Bangladesh},
	abstract = {Efficiently identifying software bugs is critical to accelerate software development processes. Traditional methods, which frequently depend on manual review or constraint-driven mechanisms, require a significant amount of time, susceptible to mistakes made by humans, and unable to scale effectively with the growing complexity of modern software systems. With texts, code snippets, and images from well-known repositories like VS Code, Flutter, Roslyn, and Kubernetes in total comprised of 4304 samples, this paper presents a new multimodal approach that uses Contrastive Language-Image Pretraining (CLIP) and its ViT-B/32 variant to effectively address this problem. We experimented with several CLIP variants, including ViT-B/32, RN50, RN101, RN50x4, ViT-B/16, ViT-L/14, and RN50x64, and observed that ViT-B/32 performed well under zero-shot settings, with an accuracy of 56.6%, precision of 54.08%, recall of 53.96% and F1-score of 54.02%, showing the usefulness of general-purpose models in task-specific situations. We performed k-fold cross-validation and hyperparameter tuning on the ViT-B/32 variant, which improved the model's ability to classify software issues with an 18.8% improvement in accuracy, 19.1% in precision, 20.14% in recall, and 19.6% in F1-score over its zero-shot performance. These findings demonstrate a scalable framework for multimodal classification that goes beyond bugs and features. This framework has potential uses in issue prioritization, automated software maintenance, and productivity tools. These findings emphasize the benefits of using multimodal AI models, such as CLIP, to tackle practical software engineering problems, providing new insights and a solid basis for further developments in this field. © 2025 IEEE.},
	author_keywords = {bug; clip; code; feature; multimodal; software issue classification; zero-shot classification},
	keywords = {Computer aided software engineering; Computer operating systems; Computer software maintenance; Computer software selection and evaluation; Software packages; Software quality; Software testing; Verification; Bug; Clip; Code; F1 scores; Feature; Multi-modal; Pre-training; Shot classification; Software issue classification; Zero-shot classification; Software design},
	correspondence_address = {Y. Arafah; Ahsanullah University of Science and Technology, Aisip Lab, Department of Computer Science and Engineering, Dhaka, Bangladesh; email: yasirarafah123.prince@gmail.com},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
