@CONFERENCE{Zalat2024246,
	author = {Zalat, Saeed Mostafa and Mohammad Hamed, Noha and Ahmed, Omaima Shoaib and Abdelmoez, Walid M.},
	title = {Providing Interpretability Dimension to Bug Severity Prediction using Pseudo-labeling Semi-Supervised Technique},
	year = {2024},
	journal = {34th International Conference on Computer Theory and Applications, ICCTA 2024},
	pages = {246 – 252},
	doi = {10.1109/ICCTA64612.2024.10974868},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105004873026&doi=10.1109%2fICCTA64612.2024.10974868&partnerID=40&md5=537975df5ca4ed5fcf6004337032535f},
	affiliations = {Arab Academy for Science, Technology and Maritime Transport, College of Computing and Information Technology, Alexandria, Egypt},
	abstract = {Ensuring bug-free software is critical for high-quality, reliable applications, but resolving bugs early can be costly. With bug repositories receiving numerous reports daily, predicting bug severity is essential for prioritization. Manually managing these reports is impractical, making automated severity prediction vital. This study addresses the challenge of limited labeled data in bug severity prediction by using semi-supervised learning, specifically pseudo-labeling. We explore various machine learning models (Random Forest, Neural Networks, SVM, and Decision Trees) to improve predictions with both labeled and pseudo-labeled data. Our results show significant improvements in accuracy, precision, recall, and F1-score, with the best models achieving up to 88.96% accuracy, including 86.66% accuracy from a neural network on the GCC dataset. We also integrate SHAP-based explainable AI techniques to enhance model interpretability. Using datasets from Mozilla, WineHQ, Freedesktop, GCC, and Eclipse, this research demonstrates how pseudo-labeling and explainability can lead to more accurate and interpretable bug severity predictions, improving software maintenance efficiency  © 2024 IEEE.},
	author_keywords = {Bug Detection; Machine Learning; pseudo-labeling; Semi-Supervised; Software Engineering; XAI},
	keywords = {Application programs; Computer operating systems; Computer software maintenance; Self-supervised learning; Software design; Software packages; Software quality; Software reliability; Verification; Bug detection; Bug-free; Interpretability; Labeled data; Labelings; Machine-learning; Neural-networks; Pseudo-labeling; Semi-supervised; XAI; Semi-supervised learning},
