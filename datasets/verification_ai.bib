	pages = {13 – 24},
	doi = {10.1109/ICSA65012.2025.00012},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105005028601&doi=10.1109%2fICSA65012.2025.00012&partnerID=40&md5=817ce6d36b3d3a8f081318383f3aa709},
	affiliations = {Universität Paderborn, Heinz Nixdorf Institut, Germany; Karlsruhe Institute of Technology (KIT), Germany},
	abstract = {Architectural knowledge (AK) of existing systems is essential for software engineers to make design decisions. Recently, Large Language Models (LLMs) trained on large-scale datasets, including software repositories, have shown promise in embedding knowledge and answering questions. However, LLMs have not been evaluated for their abilities to answer questions about AK, leaving doubts about their accuracy. This paper assesses GPT, a leading LLM, by evaluating its responses' accuracy, quality, and trustworthiness on the AK of the large-scale open-source system HDFS. We conducted an exploratory case study with 14 software engineers who posed questions to GPT and compared its responses to a predefined ground truth. The engineers rated GPT's answers with moderate quality and trustworthiness. Our findings on GPT's accuracy indicates moderate recall but lower precision, especially in identifying quality attribute solutions and design rationales. These results suggest that while GPT and similar models can provide initial insights into AK, expert validation remains necessary for reliability. This study underscores LLMs' potential and limitations to discover software AK.  © 2025 IEEE.},
	author_keywords = {Architecture design decisions; Architecture knowledge; GPT; Large Language Models},
	keywords = {Computer aided software engineering; High level languages; Program processors; Search engines; Software design; Software prototyping; Software quality; Software reliability; Verification; Architectural knowledge; Architecture design decision; Architecture designs; Architecture knowledge; Design decisions; Exploratory case studies; GPT; Language model; Large language model; Software architectural; Open source software},
