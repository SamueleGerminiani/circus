@ARTICLE{Paria2024365,
	author = {Paria, Sudipta and Dasgupta, Aritra and Bhunia, Swarup},
	title = {SPELL: An End-to-End Tool Flow for LLM-Guided Secure SoC Design for Embedded Systems},
	year = {2024},
	journal = {IEEE Embedded Systems Letters},
	volume = {16},
