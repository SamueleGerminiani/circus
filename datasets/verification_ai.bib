@CONFERENCE{Imran2025130,
	author = {Imran, Shifa and Hofmann, Fabian and Sivrikaya, Fikret and Albayrak, Sahin},
	title = {PiPD-CIRCLE: Pipeline for Predictive Distributed Container Image Registry with Cloud Backup and Lazy-Pulling in Edge Environment},
	year = {2025},
	journal = {Proceedings of the 28th Conference on Innovation in Clouds, Internet and Networks, ICIN 2025},
	pages = {130 – 134},
	doi = {10.1109/ICIN64016.2025.10942857},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105002709059&doi=10.1109%2fICIN64016.2025.10942857&partnerID=40&md5=0911ddc030923c9f3610050fd9fa09b8},
	affiliations = {GT-ARC GmbH, Berlin, Germany; DAI-Labor, Technical University of Berlin, Berlin, Germany},
	abstract = {The significance of edge computing is soaring in the rapidly evolving era of 5G/6G networks. Enhanced edge network capabilities pave the route for applications such as autonomous vehicles, telemedicine and remote patient monitoring. Given the precarious nature of edge networks, deploying software via containers has become a practical choice. Most applications require image-pulling for container startup, for which the required docker images are typically stored in a central cloud registry. Restricted bandwidth between the edge and cloud networks causes latency during the image-pulling procedure, creating a bottleneck and leading to prolonged container startup times. On the other hand, image push in edge environments poses security threats and stale states, leading to attacks and malicious content. Therefore, in this paper, we propose an end-to-end pipeline called PiPD-CIRCLE for image push and pull supported by a distributed container image registry based on peer-to-peer connections of edge nodes and a robust cloud backup to reduce container startup time. Our cloud backup enables high availability and ensures the integrity of content entering edge nodes via vulnerability scans and sign verification. Additionally, our design incorporates the concept of lazy image pulling and an AI module to predict image placement on edge nodes for handling cold starts efficiently. Experimental evaluation shows that we have achieved over 70% reduction in container startup time compared to pulling from the central Docker Hub registry while also enabling the tagging of vulnerable images at the edge entry point to mitigate security risks. © 2025 IEEE.},
	author_keywords = {cloud-edge integration; distributed; end-to-end pipeline; ipfs; predictive; registry},
	keywords = {5G mobile communication systems; Distributed cloud; Edge computing; Remote patient monitoring; Cloud-edge integration; Distributed; Edge integration; EDGE Networks; End to end; End-to-end pipeline; Ipfs; Predictive; Registry; Startup time; Bottles},
	editor = {Paganelli F. and Rojas E. and Mitton N. and Naboulsi D. and Borsatti D. and Rovedakis S.},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	isbn = {979-833154239-9},
	language = {English},
	abbrev_source_title = {Proc. Conf. Innov. Clouds, Internet Networks, ICIN},
	type = {Conference paper},
