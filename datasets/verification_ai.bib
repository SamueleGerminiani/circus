}

@CONFERENCE{Lops202529,
	author = {Lops, Andrea and Narducci, Fedelucio and Ragone, Azzurra and Trizio, Michelantonio and Bartolini, Claudio},
	title = {A System for Automated Unit Test Generation using Large Language Models and Assessment of Generated Test Suites},
	year = {2025},
	journal = {2025 IEEE International Conference on Software Testing, Verification and Validation Workshops, ICSTW 2025},
	pages = {29 – 36},
	doi = {10.1109/ICSTW64639.2025.10962454},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105004742913&doi=10.1109%2fICSTW64639.2025.10962454&partnerID=40&md5=804fbf91d93ba47b938fb7118f96aef2},
