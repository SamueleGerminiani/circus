	keywords = {Computer aided software engineering; Cost engineering; Engineering education; Requirements engineering; Cost saving; Customizability; Education and training; Language model; Large language model; Open source AI model; Open-source; Prompt engineering; Software engineering education; Software engineering training; Open source software},
