@CONFERENCE{Sudheerbabu202413,
	author = {Sudheerbabu, Gaadha and Ahmad, Tanwir and Truscan, Dragos and Vain, Juri and Porres, Ivan},
	title = {Iterative Optimization of Hyperparameter-based Metamorphic Transformations},
	year = {2024},
	journal = {Proceedings - 2024 IEEE International Conference on Software Testing, Verification and Validation Workshops, ICSTW 2024},
	pages = {13 – 20},
	doi = {10.1109/ICSTW60967.2024.00016},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85205970945&doi=10.1109%2fICSTW60967.2024.00016&partnerID=40&md5=305e243ca8d242bdc3d407b167ea7123},
	affiliations = {Åbo Akademi University, Turku, Finland; Tallinn University of Technology, Tallinn, Estonia},
	abstract = {Verification and validation of a software system to ensure compliance with the specification and intended functional behaviour often pose a challenge when it lacks an explicit test oracle. We present an efficient black-box metamorphic testing approach in which test cases are automatically generated based on metamorphic transformations. The hyperparameters of several metamorphic transformations are optimized on the fly using a generative AI with a feedback loop for optimal test generation and test suite minimization. The proposed method uses several combined metamorphic relations to define test inputs and to determine the test verdict. The feedback on test quality is evaluated based on the metamorphic relation's fitness function and used to optimize the next iterations of test generation. The effectiveness of the proposed approach is evaluated on an industrial case study of a crane's load position system which lacks an explicit test oracle. The experimental results confirm that optimizing the morphing transformations using the feedback loop improves the effectiveness of metamorphic test input generation. The outcome of the study shows that the approach can be potentially applied for functional safety verification in software systems with a test oracle problem.  © 2024 IEEE.},
	author_keywords = {Artificial Intelligence; Generative AI; Metamorphic testing; Software testing; Test Automation; Verification and Validation},
	keywords = {Automatic testing; Linear transformations; Feedback loops; Generative AI; Hyper-parameter; Metamorphic testing; Metamorphic transformations; Software testings; Software-systems; Test Automation; Test oracles; Verification-and-validation; Black-box testing},
	correspondence_address = {G. Sudheerbabu; Åbo Akademi University, Turku, Finland; email: gaadha.sudheerbabu@abo.fi},
