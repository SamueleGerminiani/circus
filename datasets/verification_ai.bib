@BOOK{Sherly202587,
	author = {Sherly, A.P. and Kumar, P. Arun Raj},
	title = {Machine Learning Approaches to Malware Detection Systems},
	year = {2025},
	journal = {Multimedia Security: Tools, Techniques, and Applications},
	pages = {87 – 114},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105005682189&partnerID=40&md5=63d7048eb3828a0421d80a7da16bcebe},
	affiliations = {Graduate Student Member, IEEE; Research Scholar, NIT Calicut, Kerala, India; Senior Member, IEEE; Department of Computer Science and Engineering, NIT Calicut, Kerala, India},
	abstract = {Due to the increasing popularity of digital media, steganography is a promising technique in critical applications such as military, healthcare, industry, space exploration, etc. For example, the malicious software sent in a stego video may affect life-or-death decisions, making fail-safe security a necessity. Such unknown or new malwares are not easy to detect. However, in the literature, to detect malware, various techniques such as static analysis, dynamic analysis, and reverse engineering exist. Static analysis analyzes the code or binary (signature based) without executing the malware. The static analysis is inefficient in the present scenario due to rapid increase in malware variants. Dynamic analysis executes the malware within a controlled environment. The dynamic analysis has limitations due to limited network access in a controlled environment. Reverse engineering involves disassembling or decompiling a software program to analyze malware. If the malicious program structure is complex, the reverse engineering framework is inefficient. Due to complex structure and hidden malicious instructions, there is a need to automate the detection process to find the malware instantly in real time. Therefore, artificial intelligence (AI) techniques such as machine learning (ML), deep learning, and fuzzy logic (FL) help especially in static and dynamic malware analysis for quick detection. To demonstrate the malware analysis in this chapter, a sample malware from the public repository is hidden in an image and analyzed using freely available Open Source Intelligence tools (OSINTs). From the experimental results, it is evident that the malware detection in stego image is indeed challenging due to its hidden behavior and malicious scripts. The primary objective of the chapter is to discuss and analyze the existing ML techniques used in detecting the presence of malware. © 2025 by Apple Academic Press, Inc.},
	author_keywords = {Automated detection techniques; Dynamic analysis; Machine learning; Malware; Manual detection techniques; Reverse engineering; Virtualization},
	keywords = {Computer software selection and evaluation; Computer viruses; Computer worms; Enterprise software; Open source software; Space applications; Space research; Verification; Virtual machine; Automated detection; Automated detection technique; Controlled environment; Dynamics analysis; Machine learning approaches; Machine-learning; Malware detection; Malwares; Manual detection technique; Virtualizations; Reverse engineering},
	publisher = {Apple Academic Press},
