@CONFERENCE{Wu2024114,
	author = {Wu, Di and Wu, Zijian and Qiu, Yuelong and Fu, Shen and Zeng, Yong},
	title = {CKMImageNet: A Comprehensive Dataset to Enable Channel Knowledge Map Construction via Computer Vision},
	year = {2024},
	journal = {International Conference on Communications in China, ICCC Workshops 2024},
