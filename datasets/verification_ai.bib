	year = {2025},
	journal = {2025 IEEE 4th International Conference on AI in Cybersecurity, ICAIC 2025},
	doi = {10.1109/ICAIC63015.2025.10848559},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85217987628&doi=10.1109%2fICAIC63015.2025.10848559&partnerID=40&md5=b682273295ae750bf508d2b6468f53fd},
	affiliations = {Texas A&M University College Station, Dept. of Computer Science, TX, United States},
	abstract = {Open-source software can reduce the cost of code use and development; however, it can also introduce vulnerabilities. Machine learning methods show promise for finding and fixing vulnerabilities in source code, but require a large amount of labeled data for training. We provide a data set generation framework for C C++ code that will identify code commits that patch vulnerabilities and provide the patched and unpatched function. The framework uses a large language model to determine if the commit patches a vulnerability, then a custom parser to extract the function before and after the patch. Our data set provides over 18,000 functions from 12 repositories. Random sampling and human verification estimate the accuracy at 8 9%. © 2025 IEEE.},
