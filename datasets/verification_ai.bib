@CONFERENCE{Baldonado2025418,
	author = {Baldonado, Juan Manuel and Bonomo-Braberman, Flavia and Braberman, Victor A.},
	title = {Towards a Probabilistic Framework for Analyzing and Improving LLM-Enabled Software},
	year = {2025},
	journal = {2025 IEEE International Conference on Software Testing, Verification and Validation Workshops, ICSTW 2025},
	pages = {418 – 422},
	doi = {10.1109/ICSTW64639.2025.10962470},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105004724347&doi=10.1109%2fICSTW64639.2025.10962470&partnerID=40&md5=c070d531a9ef2402fe9d5fac66a5cb26},
	affiliations = {Universidad de Buenos Aires, ICC UBA/CONICET and DC, FCEN, Buenos Aires, Argentina},
	abstract = {Ensuring the reliability and verifiability of large language model (LLM)-enabled systems remains a significant challenge in software engineering. We propose a probabilistic framework for systematically analyzing and improving these systems by modeling and refining distributions over clusters of semantically equivalent outputs. This framework facilitates the evaluation and iterative improvement of Transference Models- key software components that utilize LLMs to transform inputs into outputs for downstream tasks. To illustrate its utility, we apply the framework to the autoformalization problem, where natural language documentation is transformed into formal program specifications. Our case illustrates how distribution-aware analysis enables the identification of weaknesses and guides focused alignment improvements, resulting in more reliable and interpretable outputs. This principled approach offers a foundation for addressing critical challenges in the development of robust LLM-enabled systems.  © 2025 IEEE.},
	author_keywords = {autoformalization; LLMs; prompt engineering},
	keywords = {Computer aided software engineering; Computer operating systems; Computer software selection and evaluation; Formal specification; Software design; Software packages; Software quality; Software reliability; System program documentation; Verification; Autoformalization; Down-stream; Iterative improvements; Language model; LLM; Natural languages; Probabilistic framework; Prompt engineering; Software-component; Verifiability; Utility programs},
	correspondence_address = {J.M. Baldonado; Universidad de Buenos Aires, ICC UBA/CONICET and DC, FCEN, Buenos Aires, Argentina; email: juanmanuelbaldonado@gmail.com},
	editor = {Fasolino A.R. and Panichella S. and Aleti A. and Mesbah A.},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
	isbn = {979-833153467-7},
	language = {English},
	abbrev_source_title = {IEEE Int. Conf. Softw. Test., Verif. Valid. Workshops, ICSTW},
	type = {Conference paper},
