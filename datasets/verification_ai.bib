}

@CONFERENCE{Romdhani2025,
	author = {Romdhani, Raoudha and Mosbahi, Olfa and Khalgui, Mohamed},
	title = {Using Deep Learning for Deadlock Detection in Intelligent Software Systems},
	year = {2025},
	journal = {2025 International Symposium on iNnovative Informatics of Biskra, ISNIB 2025},
	doi = {10.1109/ISNIB64820.2025.10983618},
	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-105007304749&doi=10.1109%2fISNIB64820.2025.10983618&partnerID=40&md5=835124c41b21c8ae00b76da13a9ce0c5},
	affiliations = {Ept, University of Carthage, Lisi, Sercom laboratory, Tunis, 1080, Tunisia; Insat, University of Carthage, Lisi laboratory, Tunis, 1080, Tunisia; German International University GIU-Berlin, Faculty of Engineering, Berlin, 13507, Germany},
	abstract = {This paper addresses deadlocks in concurrent software systems, presenting an AI-driven testing framework for detecting deadlocks in task interactions. Using advanced machine learning techniques, the system monitors task interactions, learns from historical data, and refines its detection ability. The approach formalizes task properties, such as states, resource demands, and dependencies, to build a robust interaction model. A supervised neural network algorithm provides real-time predictions, with evaluation metrics like detection accuracy and false positive rates for comparison with conventional methods. Results show significant improvements in deadlock detection accuracy, addressing scalability and manageability challenges faced by traditional solutions, offering a scalable AI alternative for modern distributed environments.  © 2025 IEEE.},
	author_keywords = {Concurrency and Mutual Exclusion Tasks; Deadlock Verification; Deep Learning; Software Tasks; Software Testing},
