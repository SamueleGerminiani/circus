	url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85186843281&doi=10.1109%2fLRA.2024.3364471&partnerID=40&md5=b5d091ab11ec3a7b17f9de23c9a6c8d4},
	affiliations = {University of Liverpool, Department of Computer Science, Liverpool, L69 3BX, United Kingdom; University of Warwick, WMG, Coventry, CV4 7AL, United Kingdom; Imperial College London, Department of Electrical and Electronic Engineering, London, SW7 2AZ, United Kingdom},
	abstract = {Deep Reinforcement Learning (DRL) has achieved impressive performance in robotics and autonomous systems (RAS). A key challenge to its deployment in real-life operations is the presence of spuriously unsafe DRL policies. Unexplored states may lead the agent to make wrong decisions that could result in hazards, especially in applications where DRL-trained end-to-end controllers govern the behaviour of RAS. This letter proposes a novel quantitative reliability assessment framework for DRL-controlled RAS, leveraging verification evidence generated from formal reliability analysis of neural networks. A two-level verification framework is introduced to check the safety property with respect to inaccurate observations that are due to, e.g., environmental noise and state changes. Reachability verification tools are leveraged locally to generate safety evidence of trajectories. In contrast, at the global level, we quantify the overall reliability as an aggregated metric of local safety evidence, corresponding to a set of distinct tasks and their occurrence probabilities. The effectiveness of the proposed verification framework is demonstrated and validated via experiments on real RAS.  © 2016 IEEE.},
	author_keywords = {AI-enabled robotics; formal methods in robotics and automation; Robot safety},
	keywords = {Deep learning; Formal verification; Reinforcement learning; Reliability analysis; Robots; AI-enabled robotic; Formal method in robotic and automation; Power systems reliability; Reachability; Reachability analysis; Reinforcement learnings; Reliability assessments; Robot safety; Software-Reliability; Verification framework; Software reliability},
	correspondence_address = {X. Huang; University of Liverpool, Department of Computer Science, Liverpool, L69 3BX, United Kingdom; email: xiaowei.huang@liverpool.ac.uk},
	publisher = {Institute of Electrical and Electronics Engineers Inc.},
