@ARTICLE{Swaroopa2025315,
	author = {Swaroopa, Sneha and Mukherjee, Rijoy and Debnath, Anushka and Chakraborty, Rajat Subhra},
	title = {Evaluating Large Language Models for Automatic Register Transfer Logic Generation for Combinational Circuits via High-Level Synthesis},
	year = {2025},
