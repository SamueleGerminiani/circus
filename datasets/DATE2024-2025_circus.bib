 keywords = {Controllers; Data flow analysis; Deep learning; Iterative methods; Statistics; Deep learning; Feature map; Mixed precision; Mixed-precision quantization search; Modeling accuracy; Outlier value; Patch based; Patch-based inference; Quantisation; Value driven; Microcontrollers},
 language = {English},
