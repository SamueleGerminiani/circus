@conference{Ibrahimpasic2024,
 abbrev_source_title = {Proc. Des. Autom. Test Eur. DATE},
 abstract = {Scan chain is a commonly used technique in testing integrated circuits as it provides observability and controllability of the internal states of circuits. However, its presence can make circuits vulnerable to attacks and potentially result in confidential internal data leakage. In this paper, we propose a novel technique for obfuscating scan chains using camouflaged flip-flops, which are designed with the same layout as the original flip-flops but have the actual functionality of a buffer. Furthermore, we employ camouflaged logic gates interconnected in special configurations to increase the difficulty of SAT attack. Experimental results demonstrate that circuits with only a small number of flip-flops can already be protected by the proposed technique while incurring only a minimal area overhead. © 2024 EDAA.},
 affiliations = {Electronic Design Automation, Germany; Technical University Of Darmstadt, Hardware For Artificial Intelligence Group, Germany; Tu Munich, Security In Information Technology, Germany; Fraunhofer Institute For Applied And Integrated Security (AISEC), Garching b. Munich, Germany},
 author = {Ibrahimpasic, Tarik and Zhang, Grace Li and Brunner, Michaela and Sigl, Georg and Li, Bing and Schlichtmann, Ulf},
 author_keywords = {gate camouflage; scan chain obfuscation},
 isbn = {979-835034859-0},
 issn = {15301591},
 journal = {Proceedings -Design, Automation and Test in Europe, DATE},
 keywords = {Computer circuits; Logic gates; Area overhead; Data leakage; Gate camouflage; Internal state; Minimal area; Novel techniques; Scan chain; Scan chain obfuscation; Flip flop circuits},
 language = {English},
 note = {Cited by: 1},
 pages = {},
 publication_stage = {Final},
 publisher = {Institute of Electrical and Electronics Engineers Inc.},
 source = {Scopus},
 title = {ScanCamouflage: Obfuscating Scan Chains with Camouflaged Sequential and Logic Gates},
 type = {Conference paper},
 url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85196551674&partnerID=40&md5=660adce0c3d6744bfc9edfb287dc66f3},
