 keywords = {Cost reduction; Digital arithmetic; Iterative methods; % reductions; Accuracy loss; Computational costs; Floating point operations; Neural networks trainings; Neural-networks; Number of class; Pruning strategy; Pruning techniques; Weight values; Deep neural networks},
 language = {English},
