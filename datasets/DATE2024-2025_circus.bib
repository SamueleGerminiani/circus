 doi = {10.23919/DATE64628.2025.10992705},
 index_terms = {Circuit designs, Computing system, Design phase, Electronics manufacturing, Forever chemical, Polyfluoroalkyl substances, Semiconductor manufacturing, Synthetic chemicals, System designers, Technology nodes},
