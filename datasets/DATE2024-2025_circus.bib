 keywords = {Energy efficiency; RRAM; Crossbar arrays; Data intensive; Energy efficient; Inference attacks; Memory computations; Nonideality; Privacy protection; Private information; Random access memory; Resistive switching; Deep neural networks},
 language = {English},
 note = {Cited by: 0},
