 issn = {15301591},
 journal = {Proceedings -Design, Automation and Test in Europe, DATE},
 keywords = {Economic and social effects; Energy efficiency; Tuning; Efficiency benefits; Fine tuning; Gradient learning; Hardware performance; Hyper-parameter; Neural-networks; Neuromorphic computing; Sparsity-aware spiking neural network; Surrogate gradient learning; Trade off; Neural networks},
