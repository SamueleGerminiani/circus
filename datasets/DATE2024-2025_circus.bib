 keywords = {Bayesian networks; Network architecture; Neural networks; Safety engineering; Stochastic systems; Affine transformations; Bayesian neural networks; Computing architecture; Memristor; Neural-networks; Normalisation; Predictive uncertainty; Safety critical applications; Stochastics; Uncertainty; Memristors},
 language = {English},
 note = {Cited by: 1},
