 keywords = {Privacy-preserving techniques; Sensitive data; Brain-inspired; Computing scheme; High-dimensional; Higher-dimensional; Human brain functions; Multiple applications; Privacy preserving; Privacy threats; Process information; Symbolic computing; Brain},
 language = {English},
 note = {Cited by: 0},
 pages = {},
 publication_stage = {Final},
 publisher = {Institute of Electrical and Electronics Engineers Inc.},
