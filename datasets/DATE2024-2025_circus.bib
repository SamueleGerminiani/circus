 journal = {Proceedings -Design, Automation and Test in Europe, DATE},
 keywords = {Analog differential analyzers; Electric network analyzers; Chemical reaction networks; Computing demands; Computing devices; Demand-driven; Energy; Exponential growth; High performance computing systems; Intermediate representations; Multi-level intermediate representation; Multilevels; Reaction intermediates},
