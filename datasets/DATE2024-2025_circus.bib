 keywords = {Cache memory; Interactive computer systems; Memory architecture; Analyse; Analysis techniques; Cache; Cache analysis; Data Sharing; Latency bounds; Multi-cores; Real - Time system; Real- time; Shared data; Real time systems},
 language = {English},
