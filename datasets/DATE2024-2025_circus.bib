 journal = {Proceedings -Design, Automation and Test in Europe, DATE},
 keywords = {Deep learning; Dynamic frequency scaling; Multi agent systems; Reinforcement learning; Voltage scaling; Dynamic voltage and frequency scaling; Many-core; Multi-agent reinforcement learning; Performance; Performance optimizations; Q-learning; Reinforcement learnings; Runtimes; State of the art; Thermal constraints; Temperature},
 language = {English},
 note = {Cited by: 4},
 pages = {},
 publication_stage = {Final},
 publisher = {Institute of Electrical and Electronics Engineers Inc.},
 source = {Scopus},
 title = {Multi-Agent Reinforcement Learning for Thermally-Restricted Performance Optimization on Manycores},
 type = {Conference paper},
 url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85196502826&partnerID=40&md5=910112ce1385c56278a393382fbaf553},
