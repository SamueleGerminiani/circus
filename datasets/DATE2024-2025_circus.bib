 keywords = {Acceleration; Data handling; Energy efficiency; Field effect transistors; Graph neural networks; Inference engines; Ferroelectric fieldeffect transistors (FeFET); Graph neural networks; High-order; Higher-order; Hyper graph; Hyperdimensional computing; Hypergraph learning; Network-based solutions; Processing-in-memory; Real-world; Graphics processing unit},
