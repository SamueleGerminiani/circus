 keywords = {Computation theory; Dynamic random access storage; Error correction; Flash memory; Memory architecture; Search engines; Trees (mathematics); Data retrieval; Data systems; Enhanced efficiency; Equality tests; Flash chips; Flash memory chip; Hash table; Hash trees; Large scale data; Neumann architecture; Program processors},
 language = {English},
