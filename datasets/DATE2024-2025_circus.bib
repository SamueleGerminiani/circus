 issn = {15301591},
 journal = {Proceedings -Design, Automation and Test in Europe, DATE},
 keywords = {Cache memory; Cache bandwidth; Covert channels; CPU architecture; CPU microarchitecture; Key bits; Micro architectures; Performance; Prefetches; Shared memory; Side-channel; Memory architecture},
 language = {English},
 note = {Cited by: 5},
