 keywords = {Noise abatement; Pattern recognition; Defect patterns; Design cycle; Die-on wafers; Failure mechanism; Mixed type; Point set; Point-clouds; Scale-down; Technology nodes; Wafer maps; Failure (mechanical)},
 language = {English},
 note = {Cited by: 2},
