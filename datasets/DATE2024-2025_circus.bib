 keywords = {Combinatorial optimization; Cost functions; Cytology; Integer programming; Assignment problems; Assignment solutions; Clusterings; Cost-function; Integer Linear Programming; Place and route; Runtimes; Standard-cell; Standard-cell placement; Wire length; Cells},
 language = {English},
