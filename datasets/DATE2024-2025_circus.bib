 keywords = {Computational efficiency; Data privacy; Table lookup; Bit-Width; Conventional methods; Data characteristics; Hardware implementations; High-accuracy; Intrinsic data; Non-uniform quantization; Power-of-two; Quantisation; Quantization schemes; Deep neural networks},
