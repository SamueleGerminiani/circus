 doi = {10.23919/DATE64628.2025.10992756},
 index_terms = {Bit level, Computational requirements, Deep neural network acceleration, Hardware/software codesign, Memory requirements, Memory usage, Multilevels, Neural-networks, Sparsity, Unified framework},
