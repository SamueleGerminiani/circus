@conference{Pan2025,
 abbrev_source_title = {Proc. Des. Autom. Test Eur. DATE},
 abstract = {© 2025 EDAA.Ransomware has emerged as a severe privacy threat, leading to significant financial and data losses worldwide. Traditional detection methods, including static signature-based detection and dynamic behavior-based analysis, have shown limitations in effectively identifying and mitigating ever-evolving ransomware attacks. In this paper, we present a machine learning-based framework that integrates both software-level scanning along with hardware-level microprocessor activity monitoring to enhance detection performance. Specifically, this paper offers three important contributions. (1) The proposed method incorporates adversarial training to address the weaknesses of conventional static analysis against obfuscation, along with a hardware-assisted dynamic analysis to reduce detection latency. (2) The proposed method employs a neural architecture search (NAS) algorithm to automate the optimization of machine learning models, significantly boosting generalizability. (3) Experimental results demonstrates that our proposed method improves detection accuracy by up to 10.2% and reduces detection latency by up to 4.8x speedup compared to existing approaches.},
