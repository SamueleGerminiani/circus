 keywords = {Integrated circuit interconnects; Circuit emulation; Cut size; Hardware emulation; Hyper graph; IF signals; Multi-FPGA system; Partition; Physical connections; Signal paths; Very-large-scale integration circuits; Field programmable gate arrays (FPGA)},
 language = {English},
 note = {Cited by: 3},
