 keywords = {Energy conservation; Network architecture; Program processors; Systolic arrays; Feature extraction methods; Mixed precision; Neural-networks; Performance; Point-clouds; Poor performance; Pruning strategy; Quantisation; Spatial domains; Various densities; Network layers},
