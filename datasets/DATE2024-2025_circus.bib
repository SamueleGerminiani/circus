 keywords = {Energy efficiency; Systolic arrays; Accuracy-configurable; Approximate multiplier; Convolutional neural network; Divergency; Errors tolerance; High-accuracy; Inherent errors; Partial product; Partial product speculation; Performance; Convolutional neural networks},
 language = {English},
