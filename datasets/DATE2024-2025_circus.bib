 keywords = {Directed graphs; Middleware; Motion planning; Robot Operating System; Acyclic graphs; Automotives; Berkeley packet filters; Dataflow; Model synthesis; Model-based OPC; Return value; Time-critical systems; Timing Analysis; Timing modeling; Timing circuits},
