 keywords = {Digital arithmetic; Energy saving; Information management; Floating points; Floating-point arithmetic; Floating-point computation; Language model; MAtrix multiplication; Numerical accuracy; Outlier; Quantisation; Transformer; Unit-based; Energy efficiency},
