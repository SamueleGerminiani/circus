 keywords = {Energy efficiency; Image enhancement; RRAM; Energy-efficient machine; Future energies; Learning architectures; Machine-learning; Output neurons; Response signatures; Test response; Testing procedure; Tuning parameter; Two-step process; Backpropagation},
 language = {English},
 note = {Cited by: 1},
