@conference{Liu2025,
 abbrev_source_title = {Proc. Des. Autom. Test Eur. DATE},
 abstract = {© 2025 EDAA.As process nodes continue to shrink, yield estimation has become increasingly critical in modern circuit design. Traditional approaches face significant challenges: surrogate-based methods often struggle with robustness and accuracy, whereas importance sampling (IS)-based methods suffer from high simulation costs. To address these challenges simultaneously, we propose FUSIS, a unified framework that combines the strengths of surrogate-based and IS-based approaches. Unlike conventional surrogate-based methods that directly replace SPICE simulations for performance predictions, FUSIS employs a Deep Kernel support vector machine (SVM) as an approximation of the indicator function, which is further utilized to construct a quasi-optimal proposal distribution for IS to accelerate convergence. To further mitigate yield estimation bias caused by surrogate inaccuracies, we introduce a novel correction factor to adjust the IS-based yield estimation. Experiments conducted on SRAM and analog circuits demonstrate that FUSIS significantly improves accuracy by up to 24.84% (8.67% on average) while achieving up to 29.54× (10.30× on average) speedup in efficiency compared to seven state-of-the-art methods.},
 affiliations = {School of Integrated Circuit Science and Engineering, Beihang University, Beijing, China; School of Mathematical and Physical Science, University of Sheffield, S3 7RH, United Kingdom},
 author = {Liu, Yanfang and Xing, Wei W.},
 author_keywords = {Deep Kernel SVM, Importance Sampling, Surrogate Model, Yield Estimation},
