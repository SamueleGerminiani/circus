 keywords = {Analog storage; Benchmarking; Cache memory; Character recognition equipment; Cluster computing; Multicore programming; Physical addresses; Semiconductor storage; System-on-chip; Hardware accelerators; Heterogeneous computing; Heterogeneous systems; Input-output; Input-output memory management unit; Management unit; Memory-management; RISC-V; Shared virtual addressing; Systems-on-Chip; Virtual addresses},
 language = {English},
