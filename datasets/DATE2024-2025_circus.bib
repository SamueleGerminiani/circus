 keywords = {Boolean functions; Formal verification; Open systems; Boolean relations; Don't-cares; External constraints; Formal synthesis; Formal verification methods; Netlist; Operation mode; Optimisations; Optimization approach; Optimization problems; Timing circuits},
 language = {English},
 note = {Cited by: 1},
