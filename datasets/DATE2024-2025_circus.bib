 publication_stage = {Final},
 publisher = {Institute of Electrical and Electronics Engineers Inc.},
 source = {Scopus},
 title = {An Efficient Hypergraph Partitioner under Inter - Block Interconnection Constraints},
 type = {Conference paper},
 url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85196487393&partnerID=40&md5=8cfc54e392fd8447f02f9820b50b2892},
