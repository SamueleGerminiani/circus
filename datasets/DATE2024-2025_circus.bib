 source = {Scopus},
 title = {STAR: Sum-Together/Apart Reconfigurable Multipliers for Precision-Scalable ML Workloads},
 type = {Conference paper},
 url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85196546284&partnerID=40&md5=286a46274ee806e6c93994a9decbc5ba},
