 index_terms = {Bio-inspired architectures, Classical optimization, Complex problems, Dendritic computation, Dendritics, Graph, Optimization techniques, Short-path, Simple++, Sub-problems},
 isbn = {978-398267410-0},
 issn = {15301591},
 journal = {Proceedings -Design, Automation and Test in Europe, DATE},
 keywords = {Fuzzy logic; Bio-inspired architectures; Classical optimization; Complex problems; Dendritic computation; Dendritics; Graph; Optimization techniques; Short-path; Simple++; Sub-problems; Dynamic programming},
 language = {English},
 note = {Cited by: 0},
