@conference{Dasari2024,
 abbrev_source_title = {Proc. Des. Autom. Test Eur. DATE},
 abstract = {Formal verification has been successfully used to verify different types of digital circuits, including combinational and sequential logic, arithmetic circuits, and datapath designs. However, the verification techniques concentrate on confirming whether the circuit performs its intended function, while the issue of debugging, i.e., detection and correction of functional errors of the design, remains an open problem. Elaborate testing techniques have been developed that target certain types of manufacturing faults, but there are no general techniques that address the debugging issue for functional bugs. This paper addresses the issue of debugging of arithmetic circuits that due to their large size and complexity are particularly hard to verify and debug. Current debugging techniques handle only simple types of bugs: gate replacement, wrong gate polarity, or a missing gate, but cannot handle more realistic faults, such as wrong wiring or using a wrong combination of logic gates. We describe a novel method that combines formal verification and testing techniques to enable efficient identification and correction of faults. The technique involves setting select signals to some predefined constants to reduce the design to easily verifiable circuit components; these components are then verified using logic equivalence checking and SAT tools. The fault can then be identified in form or a small logic area (with a few logic gates) to be replaced by a new, functionally correct logic. The proposed technique is illustrated with debugging of different types of divider circuits up to 1024 bit-wide. © 2024 EDAA.},
 affiliations = {University Of Massachusetts, Amherst, MA, United States},
 author = {Dasari, Jiteshri and Ciesielski, MacIej},
 isbn = {979-835034859-0},
 issn = {15301591},
 journal = {Proceedings -Design, Automation and Test in Europe, DATE},
 keywords = {Computer circuits; Formal verification; Logic circuits; Timing circuits; 'current; Arithmetic circuit; Circuit designs; Combinational logic; Data path design; Functional errors; Sequential logic; Testing technique; Verification and testing; Verification techniques; Logic gates},
 language = {English},
 note = {Cited by: 1},
 pages = {},
 publication_stage = {Final},
 publisher = {Institute of Electrical and Electronics Engineers Inc.},
 source = {Scopus},
 title = {Combining Formal Verification and Testing for Debugging of Arithmetic Circuits},
 type = {Conference paper},
 url = {https://www.scopus.com/inward/record.uri?eid=2-s2.0-85196552921&partnerID=40&md5=11d2fdb8892ac82459ddfca5334ee80c},
 year = {2024}
