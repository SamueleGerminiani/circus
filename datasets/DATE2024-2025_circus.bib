 journal = {Proceedings -Design, Automation and Test in Europe, DATE},
 keywords = {Analog circuits; Circuit simulation; Iterative methods; Pareto principle; Search engines; Timing circuits; Adaptive sampling methods; Analog/mixed-signal circuits; Customisation; Lower complexity; Mixed signal; Multi-objectives optimization; Optimization framework; Signal parameters; Simulation complexity; Surrogate modeling; Multiobjective optimization},
 language = {English},
