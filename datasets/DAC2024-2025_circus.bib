@conference{Pan2024557,
 abbrev_source_title = {Proc Asia South Pac Des Autom Conf},
 abstract = {© 2024 IEEE.Attention-based models such as Transformers represent the state of the art for various machine learning (ML) tasks. Their superior performance is often overshadowed by the substantial memory requirements and low data reuse opportunities. Processing in Memory (PIM) is a promising solution to accelerate Transformer models due to its massive parallelism, low data movement costs, and high memory bandwidth utilization. Existing PIM accelerators lack the support for algorithmic optimizations like dynamic token pruning that can significantly improve the efficiency of Transformers. We identify two challenges to enabling dynamic token pruning on PIM-based architectures: the lack of an in-memory top-k token selection mechanism and the memory underutilization problem from pruning. To address these challenges, we propose PRIMATE, a software-hardware co-design PIM framework based on High Bandwidth Memory (HBM). We initiate minor hardware modifications to conventional HBM to enable Transformer model computation and top-k selection. For software, we introduce a pipelined mapping scheme and an optimization framework for maximum throughput and efficiency. PRIMATE achieves 30.6× improvement in throughput, 29.5× improvement in space efficiency, and 4.3× better energy efficiency compared to the current state-of-the-art PIM accelerator for Transformers.},
 affiliations = {University of California San Diego, La Jolla, CA, United States; Pennsylvania State University, State College, PA, United States},
