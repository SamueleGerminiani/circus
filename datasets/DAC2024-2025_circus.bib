 keywords = {Computer circuits; Graph neural networks; Hamming distance; Locks (fasteners); Machine learning; Supply chains; Corruptibility; Explainability; Fabless; Graph neural networks; Hardware intellectual property; Logic encryption; Logic locking; Machine-learning; Network-based; Semiconductor supply chain; Cryptography},
 language = {English},
