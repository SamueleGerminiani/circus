 keywords = {Autonomous vehicles; Fault detection; Fault tolerance; Interactive computer systems; Online systems; Real time systems; Safety engineering; Autonomous driving; Autonomous Vehicles; Boosting; Design time; Faults detection; Lifespans; On-line detection; Real - Time system; Time change; Worst-case execution time; Energy efficiency},
 language = {English},
