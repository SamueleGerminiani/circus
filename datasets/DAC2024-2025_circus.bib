 doi = {10.1109/ASP-DAC58780.2024.10473919},
 index_terms = {AI applications, Computing-in-memory, Hardware acceleration, Hardware optimization, Irregular sparsity, Neural-networks, Remapping, Sparse neural networks, Weight remapping, Zero-skipping},
