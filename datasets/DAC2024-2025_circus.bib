 doi = {10.1145/3649329.3657313},
 index_terms = {3D imaging, Computing in pixel, Edge aware, Edge pixels, High resolution, Images reconstruction, Large-format, Pixel formats, Single photon avalanche diode, Time-of-flight sensor},
