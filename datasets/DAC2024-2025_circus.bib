 keywords = {Authentication; Ciphertext; Computational efficiency; Cryptography; Digital storage; Edge computing; Energy efficiency; Ferroelectricity; Green computing; Network security; Computational paradigm; Computing-in-memory; Data movements; Encryption methods; Ferroelectric FeFET; Key generation; Lightweight encryption; Plaintext; Security solutions; System components; Hardware security},
