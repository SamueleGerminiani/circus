 doi = {10.1145/3649329.3655930},
 index_terms = {Accurate inference, Digital domain, Energy, Floating points, Machine-learning, Memory macro, Memory paradigm, Neural networks trainings, Neural-networks, Static random access memory},
 isbn = {979-840070601-1},
