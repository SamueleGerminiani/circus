 doi = {10.1145/3649329.3658496},
 index_terms = {Equivalence checking, Gradient ascent, Gradient's methods, Nonlinear analog circuits, Optimisations, Optimized methodologies, Search Algorithms, Space-based, State-space, State-space method},
 isbn = {979-840070601-1},
