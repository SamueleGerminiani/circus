 isbn = {979-833150304-8},
 issn = {0738100X},
 journal = {Proceedings - Design Automation Conference},
 keywords = {Computational efficiency; Design; Program processors; Structured Query Language; Tuning; Co-designs; Computational requirements; Down-stream; Energy; Fine tuning; Language model; Memory requirements; Performance; State of the art; Time requirements; Computer hardware},
