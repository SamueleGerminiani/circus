 index_terms = {Automated methods, Explicit model checking, Fixpoints, Models checking, Parallel processing, Processing capability, Property, Speed up, State explosion, Symbolic model checking},
 isbn = {979-833150304-8},
 issn = {0738100X},
 journal = {Proceedings - Design Automation Conference},
 keywords = {Boolean functions; Parallel algorithms; Automated methods; Explicit model checking; Fixpoints; Models checking; Parallel processing; Processing capability; Property; Speed up; State explosion; Symbolic model checking; Model checking},
