 doi = {10.1109/ASP-DAC58780.2024.10473976},
 index_terms = {DSP, Field programmables, Field-programmable gate array, Language processing, Natural languages, Programmable gate array, Resources utilizations, Self-attention, Sorting engine, Transformer},
 isbn = {979-835039354-5},
 journal = {Proceedings of the Asia and South Pacific Design Automation Conference, ASP-DAC},
 keywords = {Digital signal processing; Engines; Field programmable gate arrays (FPGA); Natural language processing systems; DSP; Field programmables; Field-programmable gate array; Language processing; Natural languages; Programmable gate array; Resources utilizations; Self-attention; Sorting engine; Transformer; Energy efficiency},
 language = {English},
