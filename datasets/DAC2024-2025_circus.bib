 doi = {10.1109/DAC63849.2025.11133070},
 index_terms = {% reductions, Breakings, Critical phasis, Diffusion model, Floor-planning, Floorplans, Graph networks, Heterogeneous graph, Initial solution, Wire length},
 isbn = {979-833150304-8},
