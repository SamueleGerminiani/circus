 keywords = {Acceleration; Computer hardware; Hardware-software codesign; Neural networks; Statistics; Activation outlier; Affect modeling; Compute-in-memory; Hybrid strategies; Language model; Large language model; Modeling performance; Neural network accelerator; Neural-networks; Quantisation; Chemical activation},
