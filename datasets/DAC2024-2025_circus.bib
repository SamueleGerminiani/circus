 journal = {Proceedings - Design Automation Conference},
 keywords = {Channel flow; Fluids; Integrated circuit design; Microfluidic chips; Microfluidics; Multiplexing equipment; Chip flow; Continuous-flow; Control channels; Fault tolerant microfluidics; Fault-tolerant; Flow channels; Microfluidic-chips; Multi-layered; Multiplexer designs; Volume of fluids; Fault tolerance},
