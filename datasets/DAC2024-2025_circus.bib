 isbn = {979-835039354-5},
 journal = {Proceedings of the Asia and South Pacific Design Automation Conference, ASP-DAC},
 keywords = {Computer aided design; Mapping; Memory architecture; Application level; Data movements; Hardware accelerators; Loop order; Network operator; Neural network application; Off-chip; Performance; Power-efficiency; Specialized hardware; Deep neural networks},
 language = {English},
