@conference{Zurstrasen2024686,
 abbrev_source_title = {Proc Asia South Pac Des Autom Conf},
 abstract = {© 2024 IEEE.Virtual Platforms (VPs) and Full System Simulators (FSSs) are among the fundamental tools of modern Multiprocessor System on A Chip (MPSoC) development. In the last two decades, the execution speed of these simulations did not grow at the same rate as the complexity of the systems to be simulated, creating a need for faster simulation techniques. A popular approach is temporal decoupling (TD), in which parts of the simulation are not synchronized with the rest of the system for a time called quantum. A high quantum is beneficial for simulation performance due to fewer synchronization/context switches. Yet, it also increases the probability of causality errors, leading to inaccuracies. Thus, most users of TD simulations face the question: Which quantum offers the optimal compromise between accuracy and performance? In practice and literature, the quantum is usually chosen based on empirical knowledge. This approach can achieve adequate performance/accuracy, but it lacks proper reasoning. In this work, we address this shortcoming by providing analytical estimations and deeper insights into the effects of Temporal Decoupling (TD). Additionally, we verify the proposed models using TD simulations in SystemC and gem5.},
 affiliations = {RWTH Aachen University, Institute for Communication Technologies and Embedded Systems, Germany; MachineWare GmbH, Aachen, Germany},
 author = {Zurstrasen, Niko and Brandhofer, Ruben and Cubero-Cascante, Jose and Bosbach, Nils and Junger, Lukas and Leupers, Rainer},
 author_keywords = {Full-System Simulation, gem5, Quantum, SystemC, Temporal Decoupling},
 doi = {10.1109/ASP-DAC58780.2024.10473967},
 index_terms = {Full system simulators, Full-system simulation, Fundamental tools, Gem5, Multi processor systems, Performance, Quantum, SystemC, Temporal decoupling, Virtual platform},
 isbn = {979-835039354-5},
 journal = {Proceedings of the Asia and South Pacific Design Automation Conference, ASP-DAC},
 keywords = {Multiprocessing systems; Full system simulators; Full-system simulation; Fundamental tools; Gem5; Multi processor systems; Performance; Quantum; SystemC; Temporal decoupling; Virtual platform; System-on-chip},
 language = {English},
 note = {Cited by: 4},
 pages = {686 - 691},
 per_year_citations = {2024: 2, 2025: 2, 2026: 0},
 publication_stage = {Final},
 publisher = {Institute of Electrical and Electronics Engineers Inc.},
 source = {Scopus},
 subject_areas = {Electrical and Electronic Engineering, Computer Science Applications, Computer Graphics and Computer-Aided Design},
 title = {The Optimal Quantum of Temporal Decoupling},
 total_citations = {4},
