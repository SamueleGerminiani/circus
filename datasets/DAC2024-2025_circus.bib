 isbn = {979-835039354-5},
 journal = {Proceedings of the Asia and South Pacific Design Automation Conference, ASP-DAC},
 keywords = {Constraint programming; Constraint theory; Early design phasis; End to end latencies; Hardware platform; Latency constraints; Partial order; Runtimes; Scheduling analysis; Task chains; Time-critical; Timing Analysis; Scheduling algorithms},
 language = {English},
