 journal = {Proceedings - Design Automation Conference},
 keywords = {Cost reduction; Dynamic random access storage; Memory architecture; Program processors; Activation overhead; Activation time; Area overhead; Asynchronous executions; Computation time; Conventional processing; Group level; Memory bandwidths; Performance; Processing-in-memory; Chemical activation},
