 keywords = {Dynamic random access storage; Memory architecture; AI accelerator; Autonomous driving; Cloud recognition; Feature computation; Inter-layers; Intra-layer; Multilayers perceptrons; Optimisations; Point-clouds; Random access memory; Static random access storage},
