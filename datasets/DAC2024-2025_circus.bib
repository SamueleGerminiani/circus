 keywords = {Cryptography; Digital storage; Encryption algorithms; Parallel architectures; Polynomial approximation; Polynomial regression; Reconfigurable architectures; Reconfigurable hardware; Activation functions; Ciphertexts; Data utilization; Encrypted data; Evaluation algorithm; Ho-momorphic encryptions; Homomorphic-encryptions; Multiplicative depth; Polynomial evaluation; Polynomial length},
