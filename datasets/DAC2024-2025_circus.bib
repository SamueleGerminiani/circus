 doi = {10.1109/DAC63849.2025.11132786},
 index_terms = {'current, Convergency, High-accuracy, Logical levels, Model vectors, Off-line training, Performance, Personalized model, Quantum device, Representation model},
 isbn = {979-833150304-8},
 issn = {0738100X},
 journal = {Proceedings - Design Automation Conference},
 keywords = {Qubits; 'current; Convergency; High-accuracy; Logical levels; Model vectors; Off-line training; Performance; Personalized model; Quantum device; Representation model; Vectors},
