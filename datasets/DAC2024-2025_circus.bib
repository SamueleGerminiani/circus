 keywords = {Data reduction; Hard disk storage; Information management; Information systems; Magnetic recording; Metadata; Data de duplications; Deduplication; Hard Disk Drive; Interlaced magnetic recording; Performance; Space usage; Storage capacity; Storage spaces; Updated data; Various technologies; Relocation},
