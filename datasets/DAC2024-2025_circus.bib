 doi = {10.1109/DAC63849.2025.11132928},
 index_terms = {Autonomous Vehicles, Electronic chips, Event-driven simulations, Fault's simulations, Functional Safety, Parallel patterns, Pattern fault, Performance, Simulation framework, Strongly connected component},
