 keywords = {Energy efficiency; AI applications; Computing-in-memory; Hardware acceleration; Hardware optimization; Irregular sparsity; Neural-networks; Remapping; Sparse neural networks; Weight remapping; Zero-skipping; Genetic algorithms},
