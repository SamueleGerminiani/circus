 doi = {10.1109/DAC63849.2025.11132450},
 index_terms = {Approximate computing, Behavioral descriptions, Design space exploration, Design spaces, High-level synthesis, Power, Register-transfer level, Space explorers, Synthesis design, Trade off},
 isbn = {979-833150304-8},
